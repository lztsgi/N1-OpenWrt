# =========================================================
# --- 1. 目标设备设定 (NanoPi R3S 核心架构) ---
# =========================================================
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_rockchip_armv8_DEVICE_friendlyarm_nanopi-r3s=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# =========================================================
# --- 2. 基础系统与核心工具 (启动与磁盘管理的必备用户态程序) ---
# =========================================================
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_btrfs-progs=y
CONFIG_PACKAGE_f2fs-tools=y
CONFIG_PACKAGE_xfs-fsck=y
CONFIG_PACKAGE_xfs-mkfs=y
CONFIG_PACKAGE_chattr=y
CONFIG_PACKAGE_lsattr=y
CONFIG_PACKAGE_gawk=y
CONFIG_PACKAGE_getopt=y
CONFIG_PACKAGE_pigz=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_fstrim=y
CONFIG_PACKAGE_zoneinfo-asia=y
CONFIG_PACKAGE_openssh-sftp-server=y

# =========================================================
# --- 3. 物理网络与宽带拨号 (底层驱动与 PPP 核心) ---
# =========================================================
# USB 网卡驱动 (R3S 常用外接或内置总线网卡)
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y
CONFIG_PACKAGE_kmod-usb-net-rtl8150=y
# PPPoE 拨号内核与组件
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_kmod-ppp=y
CONFIG_PACKAGE_kmod-pppoe=y
CONFIG_PACKAGE_kmod-pppox=y
CONFIG_PACKAGE_luci-proto-ppp=y

# =========================================================
# --- 4. 透明代理与流量劫持 (Clash/momo/nikki 的终极内核池) ---
# =========================================================
# TUN 模式与连接诊断
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-netlink-diag=y
CONFIG_PACKAGE_kmod-nfnetlink=y
CONFIG_PACKAGE_kmod-xdp-sockets-diag=y
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=y
# NFTables 框架与 TProxy
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-compat=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-bridge=y
# IPTables 框架、TProxy 与规则分流
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipt-extra=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_kmod-ipt-physdev=y
CONFIG_PACKAGE_kmod-ipt-conntrack=y
CONFIG_PACKAGE_kmod-ipt-fullconenat=y
CONFIG_PACKAGE_kmod-ipt-ipset=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y

# =========================================================
# --- 5. 容器与虚拟化引擎 (Docker/Podman 的底层支撑) ---
# =========================================================
# 虚拟网卡与网络隔离
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-macvlan=y
CONFIG_PACKAGE_kmod-ipvlan=y
CONFIG_PACKAGE_kmod-dummy=y
CONFIG_PACKAGE_kmod-br-netfilter=y
CONFIG_PACKAGE_kmod-nf-ipvs=y
# 容器存储层与内核参数检查
CONFIG_PACKAGE_kmod-fs-overlay=y
CONFIG_PACKAGE_kmod-ikconfig=y

# =========================================================
# --- 6. 本地存储、NAS 共享与文件系统 (全能挂载内核池) ---
# =========================================================
# USB 物理总线与 UASP 加速
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
# 现代与传统文件系统驱动
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-msdos=y
# 网络存储与内核级共享 (CIFS/NFS 挂载 + KSMBD 高性能服务端)
CONFIG_PACKAGE_kmod-fuse=y
CONFIG_PACKAGE_kmod-fs-cifs=y
CONFIG_PACKAGE_kmod-fs-nfs=y
CONFIG_PACKAGE_kmod-fs-nfs-v3=y
CONFIG_PACKAGE_kmod-fs-nfs-v4=y
CONFIG_PACKAGE_kmod-fs-ksmbd=y
# 字符集与编码支持 (防乱码必备)
CONFIG_PACKAGE_nls-utf8=y
CONFIG_PACKAGE_kmod-nls-cp932=y
CONFIG_PACKAGE_kmod-nls-cp936=y
CONFIG_PACKAGE_kmod-nls-cp950=y

# =========================================================
# --- 7. VPN、隧道协议与高级流量调度 (网络加速与 QoS) ---
# =========================================================
# 常见隧道与加密协议
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_kmod-gre=y
CONFIG_PACKAGE_kmod-mppe=y
CONFIG_PACKAGE_kmod-vxlan=y
# 拥塞控制与队列调度算法 (BBR + Cake)
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-ifb=y
